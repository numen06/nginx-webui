{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: FastAPI (后端)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SECRET_KEY": "dev-secret-key-change-in-production",
        "DATA_ROOT": "${workspaceFolder}/data"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Python: FastAPI (后端，含环境安装)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "jinja": true,
      "justMyCode": false,
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SECRET_KEY": "dev-secret-key-change-in-production",
        "DATA_ROOT": "${workspaceFolder}/data"
      },
      "preLaunchTask": "安装后端依赖（如需要）",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: FastAPI (当前文件)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "DATA_ROOT": "${workspaceFolder}/data"
      },
      "justMyCode": false
    },
    {
      "name": "Vue: 前端开发服务器",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "preLaunchTask": "安装前端依赖（如需要）",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Chrome: 调试前端",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/frontend/src",
      "breakOnLoad": true,
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      },
      "preLaunchTask": "npm: dev (frontend)"
    },
    {
      "name": "Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "Python: 调试测试",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-v",
        "--tb=short"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "DATA_ROOT": "${workspaceFolder}/data"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "完整调试: 后端 + 前端",
      "type": "compound",
      "configurations": [
        "Python: FastAPI (后端)",
        "Vue: 前端开发服务器"
      ],
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      },
      "stopAll": true
    }
  ]
}

